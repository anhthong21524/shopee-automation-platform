{
  "permissions": {
    "allowedTools": [
      "Bash(pnpm *)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npx playwright *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-npm-yarn.sh",
            "statusMessage": "Checking package manager..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-ops.sh",
            "statusMessage": "Checking for destructive operations..."
          }
        ]
      }
    ]
  }
}
