PORT=3001
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/shopee-automation

# Shopee session cookies (optional fallback)
# The crawler first tries anonymous access.
# If Shopee blocks headless Playwright or redirects to login, set SHOPEE_COOKIES.
# How to get your cookies:
#   1. Log in to shopee.vn in Chrome
#   2. Open DevTools → Application → Cookies → https://shopee.vn
#   3. Run this in the Console to export all cookies as JSON:
#      copy(JSON.stringify(document.cookie.split(';').map(c => {
#        const [name, ...rest] = c.trim().split('=');
#        return { name, value: rest.join('='), domain: '.shopee.vn', path: '/' };
#      })))
#   4. Paste the result as the value of SHOPEE_COOKIES below (single line):
SHOPEE_COOKIES=[{"name":"SPC_EC","value":"YOUR_VALUE","domain":".shopee.vn","path":"/"}]
